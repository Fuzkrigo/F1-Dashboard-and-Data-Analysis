# =============================================================================
# .env.example — F1 Insights Engine
#
# [EN] Template for the environment variables required by the application.
# Copy this file to .env and replace the placeholder values with your
# actual credentials. Used by docker-compose and the application to
# configure the PostgreSQL database connection.
#
# [PT-BR] Template das variáveis de ambiente necessárias para a aplicação.
# Copie este arquivo para .env e substitua os valores de exemplo pelas
# suas credenciais reais. Usado pelo docker-compose e pela aplicação para
# configurar a conexão com o banco de dados PostgreSQL.
#
# Author: Bruno Santos Krieger
# =============================================================================

# --- Connection string completa (tem prioridade) / Full connection string (takes priority) ---
# [EN] If set, this overrides USE_SQLITE and the POSTGRES_* parts below.
#      Put the Supabase connection string here. The real password never goes to Git.
# [PT-BR] Se definida, sobrepõe USE_SQLITE e as partes POSTGRES_* abaixo.
#      Coloque a connection string do Supabase aqui. A senha real nunca vai para o Git.
# DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- PostgreSQL via partes (docker-compose) / PostgreSQL from parts ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=f1_insights
DB_HOST=db
DB_PORT=5432
